                    <condition-expr field-name="productId" from-field="productId"/>
                </entity-condition>
            </actions>
            <widgets>
                <decorator-screen name="ProductinformationmgrCommonDecorator" location="${parameters.mainDecoratorLocation}">
                    <decorator-section name="body">
                        <decorator-screen name="EditProductTabBarDecorator" location="component://productinformationmgr/widget/CommonScreens.xml">
                            <decorator-section name="product-screens">
                                <container style="screenlet">
                                    <container style="screenlet-title-bar">
                                        <label style="h3" text="Add Facility Association for ${product.productName} [${product.productId}]"/>
                                    </container>
                                    <container style="screenlet-body">
                                        <include-form name="AddProductFacilityForProductForm" location="component://productinformationmgr/widget/ProductinformationmgrForms.xml"/>
                                    </container>
                                </container>
                                <container style="screenlet">
                                    <container style="screenlet-title-bar">
                                        <label style="h3" text="Linked Facilities"/>
                                    </container>
                                    <container style="screenlet-body">
                                        <include-form name="ListProductFacilitiesForProductForm" location="component://productinformationmgr/widget/ProductinformationmgrForms.xml"/>
                                    </container>
                                </container>
                            </decorator-section>
                        </decorator-screen>
                    </decorator-section>
                </decorator-screen>
            </widgets>
        </section>
    </screen>

</screens>