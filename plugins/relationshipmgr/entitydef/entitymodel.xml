<entitymodel xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://ofbiz.apache.org/dtds/entitymodel.xsd">
    <!-- ========================================================= -->
    <!-- ======================== Defaults ======================= -->
    <!-- ========================================================= -->
    <title>Entity of Relationshipmgr Component (Demo)</title>
    <description>Demo‑prefixed entities for the assignment.</description>
    <copyright></copyright>
    <version></version>

    <entity entity-name="DemoParty" table-name="demo_party" package-name="org.apache.ofbiz.party.demo">
        <field name="demoPartyId" type="id"/>
        <field name="demoPartyTypeId" type="id"/>
        <field name="demoStatusId" type="id"/>
        <prim-key field="demoPartyId"/>
    </entity>
    

     <entity entity-name="DemoPerson" table-name="demo_person" package-name="org.apache.ofbiz.party.demo">
        <field name="demoPersonId" type="id"/>
        <field name="firstName" type="name"/>
        <field name="lastName" type="name"/>
        <field name="gender" type="indicator"/>
        <field name="birthDate" type="date"/>
        <field name="occupation" type="name"/>
        <prim-key field="demoPersonId"/>
        <relation type="one" fk-name="DEMO_PERSON_PARTY" rel-entity-name="DemoParty">
            <key-map field-name="demoPartyId" rel-field-name="demoPartyId"/>
        </relation>

        <relation type="one" fk-name="DEMO_PERSON_EMPS_ENUM" title="EmploymentStatus" rel-entity-name="Enumeration">
            <key-map field-name="demoEmploymentStatusId" rel-field-name="enumId"/>
        </relation>

        <relation type="one" fk-name="DEMO_PERSON_RESS_ENUM" title="ResidenceStatus" rel-entity-name="Enumeration">
            <key-map field-name="demoResidenceStatusId" rel-field-name="enumId"/>
        </relation>

        <relation type="one" fk-name="DEMO_PERSON_MARITAL" title="MaritalStatus" rel-entity-name="Enumeration">
            <key-map field-name="demoMaritalStatusId" rel-field-name="enumId"/>
        </relation>
    </entity>

    <entity entity-name="DemoOrganization"
        table-name="demo_organization"
        package-name="org.apache.ofbiz.party.demo"
        title="Demo Organization">

        <field name="demoPartyId" type="id"/>
        <field name="organizationName" type="short-varchar"/>
        <field name="groupName" type="short-varchar"/>

        <prim-key field="demoPartyId"/>

        <relation type="one"
                fk-name="DEMO_ORG_PARTY"
                rel-entity-name="DemoParty">
            <key-map field-name="demoPartyId"
                    rel-field-name="demoPartyId"/>
        </relation>

    </entity>
  
     <entity entity-name="DemoPartyRole"
            table-name="demo_party_role"
            package-name="org.apache.ofbiz.party.demo"
            title="Demo Party Role">

        <field name="demoPartyId" type="id"/>
        <field name="roleTypeId" type="id"/>

        <prim-key field="demoPartyId"/>
        <prim-key field="roleTypeId"/>

        <relation type="one"
                  fk-name="DEMO_PARTY_ROLE_PARTY"
                  rel-entity-name="DemoParty">
            <key-map field-name="demoPartyId"
                     rel-field-name="demoPartyId"/>
        </relation>

    </entity>

      <entity entity-name="DemoContactMech"
            table-name="demo_contact_mech"
            package-name="org.apache.ofbiz.party.contact.demo"
            title="Demo Contact Mechanism">

        <field name="demoContactMechId" type="id"/>
        <field name="contactMechTypeId" type="id"/>
        <field name="infoString" type="very-long"/>

        <prim-key field="demoContactMechId"/>

    </entity>

     <entity entity-name="DemoPartyContactMech"
            table-name="demo_party_contact_mech"
            package-name="org.apache.ofbiz.party.contact.demo"
            title="Demo Party Contact Mechanism">

        <field name="demoPartyId" type="id"/>
        <field name="demoContactMechId" type="id"/>
        <field name="fromDate" type="date-time"/>
        <field name="allowSolicitation" type="indicator"/>

        <prim-key field="demoPartyId"/>
        <prim-key field="demoContactMechId"/>
        <prim-key field="fromDate"/>

        <relation type="one"
                  fk-name="DEMO_PCM_PARTY"
                  rel-entity-name="DemoParty">
            <key-map field-name="demoPartyId"
                     rel-field-name="demoPartyId"/>
        </relation>

        <relation type="one"
                  fk-name="DEMO_PCM_CONTACT"
                  rel-entity-name="DemoContactMech">
            <key-map field-name="demoContactMechId"
                     rel-field-name="demoContactMechId"/>
        </relation>

    </entity>

     <entity entity-name="DemoGeo"
            table-name="demo_geo"
            package-name="org.apache.ofbiz.common.geo.demo"
            title="Demo Geographic Entity">

        <field name="demoGeoId" type="id"/>
        <field name="geoName" type="short-varchar"/>
        <field name="geoTypeId" type="id"/>

        <prim-key field="demoGeoId"/>

    </entity>

    <entity entity-name="DemoPostalAddress"
            table-name="demo_postal_address"
            package-name="org.apache.ofbiz.party.contact.demo"
            title="Demo Postal Address">

        <field name="demoContactMechId" type="id"/>

        <field name="address1" type="short-varchar"/>
        <field name="address2" type="short-varchar"/>
        <field name="city" type="short-varchar"/>
        <field name="stateProvinceGeoId" type="id"/>
        <field name="postalCode" type="short-varchar"/>
        <field name="countryGeoId" type="id"/>

        <prim-key field="demoContactMechId"/>

        <relation type="one"
                  fk-name="DEMO_POSTAL_CM"
                  rel-entity-name="DemoContactMech">
            <key-map field-name="demoContactMechId"
                     rel-field-name="demoContactMechId"/>
        </relation>

        <relation type="one"
                  fk-name="DEMO_POSTAL_STATE"
                  rel-entity-name="DemoGeo">
            <key-map field-name="stateProvinceGeoId"
                     rel-field-name="demoGeoId"/>
        </relation>

        <relation type="one"
                  fk-name="DEMO_POSTAL_COUNTRY"
                  rel-entity-name="DemoGeo">
            <key-map field-name="countryGeoId"
                     rel-field-name="demoGeoId"/>
        </relation>

    </entity>


</entitymodel>